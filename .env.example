# =============================================================================
# Keylime Monitoring Dashboard — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
#   cp .env.example .env
#
# All variables have sensible defaults for local development with self-signed
# certificates and no real Keylime infrastructure.
# =============================================================================

# ---------------------------------------------------------------------------
# TLS (browser-facing reverse proxy)
# ---------------------------------------------------------------------------
# Paths on the HOST that are bind-mounted into the frontend container.
# For development, `make certs` generates self-signed certificates here.
TLS_CERT_PATH=./certs/tls.crt
TLS_KEY_PATH=./certs/tls.key

# ---------------------------------------------------------------------------
# Keylime mTLS certificates
# ---------------------------------------------------------------------------
# Paths on the HOST to the CA and client certificate/key used to connect to
# Keylime Verifier and Registrar APIs.
KEYLIME_CA_CERT=./certs/keylime-ca.crt
KEYLIME_CLIENT_CERT=./certs/keylime-client.crt
KEYLIME_CLIENT_KEY=./certs/keylime-client.key

# ---------------------------------------------------------------------------
# Keylime API endpoints
# ---------------------------------------------------------------------------
KEYLIME_VERIFIER_URL=https://localhost:8881
KEYLIME_REGISTRAR_URL=https://localhost:8891

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
RUST_LOG=info
LISTEN_ADDR=0.0.0.0:8080

# ---------------------------------------------------------------------------
# TimescaleDB
# ---------------------------------------------------------------------------
POSTGRES_DB=keylime_dashboard
POSTGRES_USER=keylime
POSTGRES_PASSWORD=changeme

# Connection string used by the backend
DATABASE_URL=postgresql://keylime:changeme@timescaledb:5432/keylime_dashboard

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Frontend / nginx
# ---------------------------------------------------------------------------
BACKEND_HOST=backend
BACKEND_PORT=8080

# ---------------------------------------------------------------------------
# Exposed host port
# ---------------------------------------------------------------------------
# The HTTPS port mapped to the host. Only the frontend is exposed.
HOST_HTTPS_PORT=8443

# ---------------------------------------------------------------------------
# Image tags (used by compose.yaml)
# ---------------------------------------------------------------------------
FRONTEND_IMAGE_TAG=latest
BACKEND_IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Production overrides (uncomment as needed)
# ---------------------------------------------------------------------------
# RUST_LOG=warn
# POSTGRES_PASSWORD=<strong-random-password>
# HOST_HTTPS_PORT=443
